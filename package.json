{
  "name": "quiztaker",
  "version": "1.0.0",
  "description": "Vitriol hosted control plane and local Windows helper for Saba learning automation.",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "main": "index.js",
  "scripts": {
    "start": "npm run start --workspace=@quiztaker/web",
    "dev": "npm run dev --workspace=@quiztaker/web",
    "dev:web": "npm run dev --workspace=@quiztaker/web",
    "dev:helper": "npm run dev --workspace=@quiztaker/helper",
    "start:legacy": "node server.js",
    "dev:legacy": "node --watch server.js --port 4000",
    "build": "node --env-file-if-exists=.env.local scripts/build-workspaces.mjs",
    "typecheck": "npm run build --workspace=@quiztaker/core && npm run typecheck --workspaces --if-present",
    "test": "node --test *.test.js && npm run test --workspaces --if-present",
    "test:db": "node --env-file=.env.local scripts/verify-neon.mjs",
    "db:migrate": "node --env-file=.env.local scripts/migrate-neon.mjs",
    "migrate:learning": "node migrate-learning-data.js",
    "release:helper": "npm run package:win --workspace=@quiztaker/helper"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.19.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "postgres": "^3.4.7"
  },
  "overrides": {
    "@better-auth/passkey": "1.6.24",
    "better-auth": "1.6.24",
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  }
}
