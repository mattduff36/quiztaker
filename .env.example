# Neon database and Managed Auth
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host.region.aws.neon.tech/database?sslmode=require
NEON_AUTH_BASE_URL=https://your-auth-host.neonauth.region.aws.neon.tech/database/auth
NEON_AUTH_COOKIE_SECRET=replace_with_at_least_32_random_characters
ALLOWED_EMAIL=operator@example.com
HELPER_MASTER_KEY=replace_with_at_least_32_random_characters

# Vercel supplies OIDC credentials automatically when a private Blob store is
# connected. Use a token only for local artifact upload/download testing.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me
NEXT_PUBLIC_SITE_URL=http://localhost:3000
GITHUB_REPOSITORY=mattduff36/quiztaker

# apps/helper (development overrides)
QUIZTAKER_HOME=C:\Users\you\AppData\Local\QuizTaker Helper
QUIZTAKER_AUTOMATION_ROOT=C:\path\to\quiztaker
PLAYWRIGHT_CDP_PORT=9222
