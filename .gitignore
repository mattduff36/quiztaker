# The application creates these directories when needed.
data/
archive/

# Downloaded research/reference artifacts are not application source.
*.pdf
*.zip
quickspecs/
DL*-QS.txt
TASK.txt

# Test and tool output.
coverage/
playwright-report/
test-results/
npm-debug.log*
